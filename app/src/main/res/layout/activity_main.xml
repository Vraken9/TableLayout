<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_ivory">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Toko Bunga Sejahtera"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/sage_green_dark"
            android:gravity="center"
            android:layout_marginTop="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daftar Harga Grosir"
            android:textSize="16sp"
            android:textColor="@color/text_medium"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <TableLayout
            android:id="@+id/main_table"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/table_border"
            android:stretchColumns="1">

            <!-- Header Row -->
            <TableRow
                android:background="@drawable/header_bg"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="No"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="Jenis Bunga"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="Satuan"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="Harga (Rp)"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:textColor="@color/white" />
            </TableRow>

            <!-- Line Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/divider_color"/>

            <!-- Item 1 -->
            <TableRow
                android:background="@color/white"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="1"
                    android:textColor="@color/text_medium"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mawar (Merah/Putih)"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Grade A, Lokal"
                        android:textSize="12sp"
                        android:textColor="@color/text_light" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="10 Tangkai"
                    android:textColor="@color/text_dark"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="120.000"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:gravity="end" />
            </TableRow>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color"/>

            <!-- Item 2 -->
            <TableRow
                android:background="@color/white"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="2"
                    android:textColor="@color/text_medium"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tulip (Kuning/Pink)"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Import, Premium"
                        android:textSize="12sp"
                        android:textColor="@color/text_light" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="5 Tangkai"
                    android:textColor="@color/text_dark"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="150.000"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:gravity="end" />
            </TableRow>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color"/>

            <!-- Item 3 -->
            <TableRow
                android:background="@color/white"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="3"
                    android:textColor="@color/text_medium"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anggrek Bulan"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mekar, Pot Keramik"
                        android:textSize="12sp"
                        android:textColor="@color/text_light" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="1 Pot"
                    android:textColor="@color/text_dark"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="200.000"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:gravity="end" />
            </TableRow>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider_color"/>

            <!-- Item 4 -->
            <TableRow
                android:background="@drawable/footer_bg"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="4"
                    android:textColor="@color/text_medium"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lily (Casablanca)"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wangi, Grade A"
                        android:textSize="12sp"
                        android:textColor="@color/text_light" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="5 Tangkai"
                    android:textColor="@color/text_dark"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:text="180.000"
                    android:textColor="@color/text_dark"
                    android:textStyle="bold"
                    android:gravity="end" />
            </TableRow>

        </TableLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="* Harga dapat berubah sewaktu-waktu tanpa pemberitahuan."
            android:textSize="12sp"
            android:textColor="@color/text_light"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</ScrollView>
